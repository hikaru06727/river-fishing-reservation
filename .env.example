# =============================================================================
# 川釣り予約サービス — 環境変数テンプレート
# コピー: cp .env.example .env.local
# 詳細: docs/env-vars.md
# =============================================================================

# --- Supabase（必須）---
# 形式: https://<project-ref>.supabase.co （"-project" は含めない）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。ブラウザに露出させないこと
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe（必須: オンライン決済を使う場合）---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 現行実装では未使用（Checkout リダイレクト方式）
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- App URL（必須）---
# 末尾スラッシュなし。Checkout リダイレクト・Auth メールに使用
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email / Resend（本番でメール通知する場合）---
EMAILS_ENABLED=false
RESEND_API_KEY=
MAIL_FROM=
# admin 通知のフォールバック先（任意）
ADMIN_NOTIFICATION_EMAIL=

# --- 開発専用（本番では未設定推奨）---
# /api/admin/set-role, set-password, /api/dev/send-test-email の保護
# production では API 自体が 403 だが、Secret には載せないこと
ADMIN_SECRET=

# --- E2E テスト（任意）---
# PLAYWRIGHT_BASE_URL=http://localhost:3000
