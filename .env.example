# =============================================================================
# 川釣り予約サービス — 環境変数テンプレート
# コピー: cp .env.example .env.local
# 詳細: docs/env-vars.md
# =============================================================================

# --- Supabase（必須）---
# 形式: https://<project-ref>.supabase.co （"-project" は含めない）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。ブラウザに露出させないこと
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe（必須: オンライン決済を使う場合）---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 現行実装では未使用（Checkout リダイレクト方式）
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- App URL（必須）---
# 末尾スラッシュなし。Checkout リダイレクト・Auth メールに使用
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email / Resend（トランザクションメール: 予約・決済・キャンセル通知）---
# 詳細: docs/email-setup.md
#
# ローカルで送信を試す最低設定:
#   EMAILS_ENABLED=true
#   RESEND_API_KEY=re_...          # https://resend.com/api-keys
#   MAIL_FROM=予約 <onboarding@resend.dev>   # 開発は Resend 共有ドメイン可。本番は自ドメイン要 DNS 検証
#
# false / 未設定のときは送信 skip（予約・決済処理は継続）
EMAILS_ENABLED=false
RESEND_API_KEY=
MAIL_FROM=
# business_admin が未割当の事業向け admin 通知フォールバック（任意）
ADMIN_NOTIFICATION_EMAIL=

# --- 開発専用（本番では未設定推奨）---
# /api/admin/set-role, set-password, /api/dev/send-test-email の保護
# production では API 自体が 403 だが、Secret には載せないこと
ADMIN_SECRET=

# --- E2E テスト（任意）---
# PLAYWRIGHT_BASE_URL=http://localhost:3000
